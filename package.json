{
  "name": "@agentg/oclif-learn",
  "description": "A new CLI generated with oclif",
  "version": "0.0.18",
  "author": "lipanpan-hub",
  "bin": {
    "oclifLearn": "./bin/run.js",
    "ofl": "./bin/run.js",
    "ofld": "./bin/dev.js"
  },
  "bugs": "https://github.com/lipanpan-hub/oclifLearn/issues",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@oclif/core": "^4",
    "@oclif/plugin-autocomplete": "^3.2.40",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-not-found": "^3.2.74",
    "@oclif/plugin-plugins": "^5",
    "@oclif/plugin-update": "^4.7.19",
    "@oclif/plugin-version": "^2.2.36",
    "@oclif/plugin-warn-if-update-available": "^3.1.55"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/debug": "^4.1.12",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^10",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/lipanpan-hub/oclifLearn",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "ofl",
    "dirname": "oclifLearn",
    "commands": "./dist/commands",
    "hooks": {
      "init": "./dist/hooks/init",
      "prerun": "./dist/hooks/prerun",
      "postrun": "./dist/hooks/postrun"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins",
      "@oclif/plugin-autocomplete",
      "@oclif/plugin-not-found",
      "@oclif/plugin-warn-if-update-available",
      "@oclif/plugin-version",
      "@oclif/plugin-update"
    ],
    "topicSeparator": " ",
    "topics": {
      "hello": {
        "description": "Say hello to the world and others"
      }
    }
  },
  "repository": "lipanpan-hub/oclifLearn",
  "scripts": {
    "build": "shx rm -rf dist tsconfig.tsbuildinfo && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md",
    "pack:tarballs": "oclif pack tarballs",
    "pack:win": "oclif pack win",
    "pack:win-tarball": "oclif pack tarballs --targets win32-x64,win32-x86,win32-arm64",
    "pack:macos": "oclif pack macos",
    "pack:deb": "oclif pack deb"
  },
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  }
}
